<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1149">
    <zorder>0</zorder>
    <defaultcontrol always="true">6501</defaultcontrol>
    <onload>CancelAlarm(osd_timeout,true)</onload>
    <controls>

        <control type="image">
            <visible>!Skin.HasSetting(CommentOverlayDisabled)</visible>
            <texture colordiffuse="B2000000">common/black.png</texture>
        </control>

        <control type="group">
            <left>160</left>
            <right>160</right>
            <height>1440</height>
            <centertop>50%</centertop>

            <control type="group">
                <height>120</height>
                <control type="label">
                    <left>0</left><top>0</top><width>100%</width><height>80</height>
                    <font>Reg37</font><textcolor>text_white</textcolor>
                    <label>$INFO[Window(10000).Property(nc_current_artist_name)]</label>
                </control>
            </control>

            <control type="group">
                <top>140</top>
                <bottom>0</bottom>

                <control type="group">
                    <left>0</left>
                    <centertop>50%</centertop>
                    <height>400</height>
                    <width>400</width>
                    <control type="image">
                        <width>400</width>
                        <height>400</height>
                        <texture background="true">$INFO[Window(10000).Property(nc_current_artist_pic)]</texture>
                        <aspectratio>scale</aspectratio>
                        <visible>!String.IsEmpty(Window(10000).Property(nc_current_artist_pic))</visible>
                    </control>
                    <control type="image">
                        <width>400</width>
                        <height>400</height>
                        <texture colordiffuse="panel_background">common/box.png</texture>
                        <visible>String.IsEmpty(Window(10000).Property(nc_current_artist_pic))</visible>
                    </control>
                </control>

                <control type="group">
                    <left>440</left>
                    <right>0</right>
                    <centertop>50%</centertop>
                    <height>400</height>
                    <control type="label">
                        <left>0</left>
                        <height>80</height>
                        <font>Reg37</font>
                        <textcolor>text_white</textcolor>
                        <label>$INFO[Window(10000).Property(nc_current_artist_name)]</label>
                        <scroll>true</scroll>
                    </control>
                    <control type="textbox">
                        <left>0</left>
                        <top>100</top>
                        <bottom>0</bottom>
                        <font>Reg20</font>
                        <textcolor>text_sublabel</textcolor>
                        <label>$INFO[Window(10000).Property(nc_current_artist_desc)]</label>
                        <autoscroll delay="5000" time="2000" repeat="10000">true</autoscroll>
                    </control>
                </control>

                <control type="button" id="6501">
                    <left>0</left>
                    <top>0</top>
                    <width>100%</width>
                    <height>100%</height>
                    <texturenofocus />
                    <texturefocus />
                    <onclick>Close</onclick>
                    <onclick>AlarmClock(musicosd_nav,ActivateWindow(1155),00:00,silent)</onclick>
                    <onup condition="!Skin.HasSetting(MusicOSD.OnDown.Disable1144)">Close</onup>
                    <onup condition="!Skin.HasSetting(MusicOSD.OnDown.Disable1144)">AlarmClock(musicosd_nav,ActivateWindow(1144),00:00,silent)</onup>
                </control>
            </control>
        </control>

    </controls>
</window>