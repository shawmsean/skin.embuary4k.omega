<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1162">
    <zorder>0</zorder>
    <defaultcontrol always="true">7001</defaultcontrol>
    <onunload>AlarmClock(reopen_comments,ActivateWindow(1142),00:00,silent)</onunload>

    <controls>

        <control type="image">
            <texture colordiffuse="B2000000">common/black.png</texture>
        </control>

        <control type="group">
            <left>80</left>
            <right>80</right>
            <height>720</height>
            <bottom>200</bottom>

            <control type="group">
                <height>50</height>
                <control type="label">
                    <left>0</left><top>10</top><width>auto</width><height>36</height>
                    <font>Reg24</font><textcolor>text_white</textcolor>
                    <label>回复</label>
                </control>
                <control type="label">
                    <left>80</left><top>10</top><width>1600</width><height>36</height>
                    <font>Reg16</font><textcolor>text_sublabel</textcolor>
                    <scroll>true</scroll>
                    <label>$INFO[Window(10000).Property(nc_reply_comment_summary)]</label>
                </control>
                <control type="label">
                    <right>16</right><top>10</top><width>auto</width><height>24</height>
                    <font>Reg16</font><textcolor>softgrey</textcolor><align>right</align>
                    <label>$INFO[Window(10000).Property(nc_reply_total),共 , 条回复]</label>
                </control>
            </control>

            <control type="list" id="7001">
                <left>0</left><right>0</right><top>60</top><bottom>10</bottom>
                <orientation>vertical</orientation>
                <scrolltime>300</scrolltime>
                <onleft>Close</onleft>
                <onright>Close</onright>
                <ondown condition="!String.IsEqual(Container(7001).ListItem.Property(is_trigger),1)">SetFocus(7001)</ondown>
                <ondown condition="String.IsEqual(Container(7001).ListItem.Property(is_trigger),1)">SetProperty(nc_reply_content_url,$INFO[Container(7001).ListItem.Property(next_page)],10000)</ondown>
                <ondown condition="String.IsEqual(Container(7001).ListItem.Property(is_trigger),1)">Container.Update($INFO[Container(7001).ListItem.Property(next_page)],replace)</ondown>
                <content>$INFO[Window(10000).Property(nc_reply_content_url)]</content>

                <itemlayout width="1760" height="100">
                    <control type="image">
                        <texture colordiffuse="panel_background" border="10">common/box.png</texture>
                    </control>
                    <control type="image">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>12</left><top>20</top><width>44</width><height>44</height>
                        <texture background="true">$INFO[ListItem.Icon]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>12</top><width>500</width><height>24</height>
                        <font>Reg20</font><textcolor>text_white</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <right>16</right><top>12</top><width>auto</width><height>24</height>
                        <font>Reg16</font><textcolor>softgrey</textcolor><align>right</align>
                        <label>$INFO[ListItem.Property(reply_floor),#,]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>34</top><width>400</width><height>20</height>
                        <font>Reg16</font><textcolor>text_sublabel</textcolor>
                        <label>$INFO[ListItem.Property(reply_time)]$INFO[ListItem.Property(reply_location), | 来自,]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <right>16</right><top>34</top><width>auto</width><height>20</height>
                        <font>Reg16</font><textcolor>text_sublabel</textcolor><align>right</align>
                        <label>$INFO[ListItem.Property(reply_liked),&#x2764; ,]</label>
                    </control>
                    <control type="textbox">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>56</top><right>16</right><bottom>8</bottom>
                        <font>Reg16</font><textcolor>white</textcolor>
                        <label>$INFO[ListItem.Property(reply_content)]</label>
                        <autoscroll delay="6000" time="3000" repeat="10000">!Control.HasFocus(7001)</autoscroll>
                    </control>
                    <control type="label">
                        <visible>String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>0</left><top>0</top><width>1760</width><height>100</height>
                        <font>Reg20</font><textcolor>text_sublabel</textcolor>
                        <align>center</align><aligny>center</aligny>
                        <label>加载更多</label>
                    </control>
                </itemlayout>

                <focusedlayout width="1760" height="100">
                    <control type="image">
                        <texture colordiffuse="$VAR[PlayerAccentColor]" border="10">common/box.png</texture>
                    </control>
                    <control type="image">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>12</left><top>20</top><width>44</width><height>44</height>
                        <texture background="true">$INFO[ListItem.Icon]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>12</top><width>500</width><height>24</height>
                        <font>Reg20</font><textcolor>selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <right>16</right><top>12</top><width>auto</width><height>24</height>
                        <font>Reg16</font><textcolor>selected</textcolor><align>right</align>
                        <label>$INFO[ListItem.Property(reply_floor),#,]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>34</top><width>400</width><height>20</height>
                        <font>Reg16</font><textcolor>selected</textcolor>
                        <label>$INFO[ListItem.Property(reply_time)]$INFO[ListItem.Property(reply_location), | 来自,]</label>
                    </control>
                    <control type="label">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <right>16</right><top>34</top><width>auto</width><height>20</height>
                        <font>Reg16</font><textcolor>selected</textcolor><align>right</align>
                        <label>$INFO[ListItem.Property(reply_liked),&#x2764; ,]</label>
                    </control>
                    <control type="textbox">
                        <visible>!String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>64</left><top>56</top><right>16</right><bottom>8</bottom>
                        <font>Reg16</font><textcolor>white</textcolor>
                        <label>$INFO[ListItem.Property(reply_content)]</label>
                        <autoscroll delay="6000" time="3000" repeat="10000">!Control.HasFocus(7001)</autoscroll>
                    </control>
                    <control type="label">
                        <visible>String.IsEqual(ListItem.Property(is_trigger),1)</visible>
                        <left>0</left><top>0</top><width>1760</width><height>100</height>
                        <font>Reg20</font><textcolor>selected</textcolor>
                        <align>center</align><aligny>center</aligny>
                        <label>加载更多</label>
                    </control>
                </focusedlayout>
            </control>
        </control>

    </controls>
</window>