<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="Wide_View_50">
		<param name="mainlabel">$VAR[MainListLabel]</param>
		<param name="sublabel">$VAR[SubListLabel]</param>
		<param name="layout">LandscapeLayout</param>
		<param name="use_custom_content">false</param>
		<definition>
			<control type="group">
				<include>Visible_OpenClose</include>
				<animation effect="slide" condition="Skin.HasSetting(HideWideLabels) + !$EXP[ForceLabels] + ![[Integer.IsGreaterOrEqual(Container(50).CurrentItem,12) + Container.HasParent] | Integer.IsGreaterOrEqual(Container(50).CurrentItem,13) | Container(50).HasPrevious] + Window.IsVisible(myvideonav.xml)" time="200" end="0,90">Conditional</animation>
				<visible>Control.IsVisible(50)</visible>
				<control id="50" type="panel">
					<visible>$EXP[WideViewVisible]</visible>
					<include>FocusBounce</include>
					<width>3840</width>
					<height>2160</height>
					<onright condition="Control.IsVisible(7000)">SetFocus(7000)</onright>
					<onright condition="!Control.IsVisible(7000) + Control.IsVisible(17)">17</onright>
					<onright>noop</onright>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">SetProperty(bili_auto_loading,1,Home)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">SetProperty(bili_refocus_index,$INFO[Window(10000).Property(bili_trigger_index)],Home)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">Container.Update($INFO[Container(50).ListItem.Property(next_page)],replace)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode1,Container.SetViewMode(50),00:00,silent)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode2,Container.SetViewMode(50),00:00.5,silent)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_refocus,SetFocus(50,$INFO[Window(Home).Property(bili_refocus_index)],absolute),00:00.5,silent)</ondown>
					<ondown condition="String.IsEqual(Container(50).ListItem.Property(is_trigger),1) + !String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_clear_loading,ClearProperty(bili_auto_loading,Home),00:02,silent)</ondown>
					<ondown>noop</ondown>
					<onup>SetFocus(6666)</onup>
					<onleft>900</onleft>
					<orientation>vertical</orientation>
					<preloaditems>4</preloaditems>
					<defaultcontrol always="true">0</defaultcontrol>
					<viewtype label="$LOCALIZE[31004]">panel</viewtype>
					<pagecontrol>17</pagecontrol>
					<include>ScrollTime</include>
					<oninfo condition="String.IsEqual(ListItem.DBType,set) + !String.IsEmpty(Container(2001).ListItem.Label)">RunScript(script.embuary.helper,action=textviewer,header='$ESCINFO[ListItem.Title]',message='$ESCVAR[ListViewPlot]')</oninfo>
					<oninfo condition="String.IsEqual(ListItem.DBType,musicvideo) + !String.IsEmpty(ListItem.Plot)">RunScript(script.embuary.helper,action=textviewer,header='$ESCINFO[ListItem.Title]',message='$ESCVAR[ListViewPlot]')</oninfo>
					<itemlayout condition="[!Skin.HasSetting(HideWideLabels) | !Window.IsVisible(myvideonav.xml) | $EXP[ForceLabels]] + ![String.IsEqual(Skin.String(EPGar),4to3) + String.StartsWith(Container.Folderpath,pvr://)]" width="450" height="305">
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<visible>false</visible>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>122</top>
							<include content="$PARAM[layout]">
								<param name="mainlabel" value="$PARAM[mainlabel]" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="focused" value="false" />
								<param name="id" value="50" />
							</include>
						</control>
					</itemlayout>
					<focusedlayout condition="[!Skin.HasSetting(HideWideLabels) | !Window.IsVisible(myvideonav.xml) | $EXP[ForceLabels]] + ![String.IsEqual(Skin.String(EPGar),4to3) + String.StartsWith(Container.Folderpath,pvr://)]" width="450" height="305">
						<include content="SetPropertyOnFocus">
							<param name="id" value="50"/>
						</include>
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">SetProperty(bili_auto_loading,1,Home)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">Container.Update($INFO[ListItem.Property(next_page)],replace)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode1,Container.SetViewMode(50),00:00,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode2,Container.SetViewMode(50),00:00.5,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_clear_loading,ClearProperty(bili_auto_loading,Home),00:02,silent)</onfocus>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>122</top>
							<include content="$PARAM[layout]">
								<param name="mainlabel" value="$PARAM[mainlabel]" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="focused" value="true" />
								<param name="id" value="50" />
							</include>
						</control>
					</focusedlayout>
					<itemlayout condition="Skin.HasSetting(HideWideLabels) + Window.IsVisible(myvideonav.xml) + !$EXP[ForceLabels]" width="450" height="259">
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<visible>false</visible>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>32</top>
							<include content="$PARAM[layout]">
								<param name="mainlabel" value="" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="labels_visible" value="false" />
								<param name="focused" value="false" />
								<param name="id" value="50" />
							</include>
						</control>
					</itemlayout>
					<focusedlayout condition="Skin.HasSetting(HideWideLabels) + Window.IsVisible(myvideonav.xml) + !$EXP[ForceLabels]" width="450" height="259">
						<include content="SetPropertyOnFocus">
							<param name="id" value="50"/>
						</include>
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">SetProperty(bili_auto_loading,1,Home)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">Container.Update($INFO[ListItem.Property(next_page)],replace)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode1,Container.SetViewMode(50),00:00,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode2,Container.SetViewMode(50),00:00.5,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_clear_loading,ClearProperty(bili_auto_loading,Home),00:02,silent)</onfocus>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>32</top>
							<include content="$PARAM[layout]">
								<param name="mainlabel" value="" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="labels_visible" value="false" />
								<param name="focused" value="true" />
								<param name="id" value="50" />
							</include>
						</control>
					</focusedlayout>
					<itemlayout condition="String.IsEqual(Skin.String(EPGar),4to3) + String.StartsWith(Container.Folderpath,pvr://)" width="360" height="305">
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<visible>false</visible>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>122</top>
							<include content="PVR4to3Layout">
								<param name="mainlabel" value="$PARAM[mainlabel]" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="focused" value="false" />
								<param name="id" value="50" />
							</include>
						</control>
					</itemlayout>
					<focusedlayout condition="String.IsEqual(Skin.String(EPGar),4to3) + String.StartsWith(Container.Folderpath,pvr://)" width="360" height="305">
						<include content="SetPropertyOnFocus">
							<param name="id" value="50"/>
						</include>
						<control type="group" condition="String.IsEqual(ListItem.Property(is_trigger),1)">
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">SetProperty(bili_auto_loading,1,Home)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">Container.Update($INFO[ListItem.Property(next_page)],replace)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode1,Container.SetViewMode(50),00:00,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_viewmode2,Container.SetViewMode(50),00:00.5,silent)</onfocus>
							<onfocus condition="!String.IsEqual(Window(Home).Property(bili_auto_loading),1)">AlarmClock(bili_clear_loading,ClearProperty(bili_auto_loading,Home),00:02,silent)</onfocus>
						</control>
						<control type="group" condition="!String.IsEqual(ListItem.Property(is_trigger),1)">
							<left>70</left>
							<top>122</top>
							<include content="PVR4to3Layout">
								<param name="mainlabel" value="$PARAM[mainlabel]" />
								<param name="sublabel" value="" />
								<param name="thumblabel" value="$PARAM[thumblabel]" />
								<param name="focused" value="true" />
								<param name="id" value="50" />
							</include>
						</control>
					</focusedlayout>
					<include condition="$PARAM[use_custom_content]" content="ContainerContentPath">
						<param name="widget_target">$PARAM[widget_target]</param>
						<param name="sortby">$PARAM[sortby]</param>
						<param name="sortorder">$PARAM[sortorder]</param>
						<param name="limit">$PARAM[limit]</param>
						<param name="content">$PARAM[content]</param>
					</include>
				</control>
				<control type="group">
					<visible>String.IsEqual(Window(Home).Property(bili_auto_loading),1)</visible>
					<animation effect="fade" start="0" end="100" time="200">Visible</animation>
					<animation effect="fade" start="100" end="0" time="200">Hidden</animation>
					<centertop>50%</centertop>
					<centerleft>50%</centerleft>
					<width>120</width>
					<height>120</height>
					<control type="image">
						<texture colordiffuse="80000000" border="60">dialogs/context/bg.png</texture>
						<aspectratio>scale</aspectratio>
					</control>
					<control type="image">
						<centertop>50%</centertop>
						<centerleft>50%</centerleft>
						<width>60</width>
						<height>60</height>
						<texture colordiffuse="selected">special://skin/extras/spinner.apng</texture>
						<aspectratio>scale</aspectratio>
					</control>
				</control>
			</control>
		</definition>
	</include>
</includes>